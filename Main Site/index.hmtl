<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Tobacco Center | Boutique Cigar Lounge | Williamsport, PA | Veteran-Owned</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Josefin+Sans:wght@300;400;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --black: #001b16; --dark: #001b16; --forest: #033d33; --jungle: #022e27;
  --teal: #0d6354; --teal-light: #259f8a; --mint: #259f8a; --mint-pale: #e0fef8;
  --gold: #c9a84c; --gold-light: #e8c76a;
  --cream: #f0fdf8; --warm-white: #f7fffe;
  --text: #001b16; --text-muted: #0d4a3a; --border: #9dd4c8;
  --font-display: 'Playfair Display', Georgia, serif;
  --font-body: 'Libre Baskerville', Georgia, serif;
  --font-sans: 'Josefin Sans', sans-serif;
}
html { scroll-behavior: smooth; }
body { font-family: var(--font-body); background: var(--warm-white); color: var(--text); font-size: 16px; line-height: 1.7; }

/* NAV */
.site-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: var(--black); border-bottom: 1px solid rgba(77,191,138,0.2); padding: 0 2rem; display: flex; align-items: center; justify-content: space-between; height: 64px; }
.nav-logo { font-family: var(--font-display); color: var(--mint); font-size: 15px; letter-spacing: 0.06em; text-decoration: none; font-weight: 700; text-transform: uppercase; }
.nav-logo span { font-style: italic; font-weight: 400; color: rgba(168,230,200,0.55); font-size: 11px; display: block; letter-spacing: 0.12em; }
.nav-links { display: flex; gap: 1.5rem; list-style: none; }
.nav-links a { font-family: var(--font-sans); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.55); text-decoration: none; transition: color 0.2s; }
.nav-links a:hover { color: var(--mint); }

/* SHARED */
.page-section { padding-top: 64px; }
.eyebrow { font-family: var(--font-sans); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--mint); display: block; margin-bottom: 1rem; }
.eyebrow.gold { color: var(--gold-light); }
.eyebrow.dark-teal { color: var(--teal); }
.leaf { position: absolute; pointer-events: none; }

.btn-primary { font-family: var(--font-sans); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; background: var(--mint); color: var(--black); padding: 14px 28px; border: none; cursor: pointer; text-decoration: none; display: inline-block; font-weight: 600; transition: background 0.2s; }
.btn-primary:hover { background: var(--mint-pale); color: var(--forest); }
.btn-ghost { font-family: var(--font-sans); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; background: transparent; color: var(--cream); padding: 13px 28px; border: 1px solid rgba(77,191,138,0.4); cursor: pointer; text-decoration: none; display: inline-block; transition: border-color 0.2s, color 0.2s; }
.btn-ghost:hover { border-color: var(--mint); color: var(--mint); }
.btn-gold { font-family: var(--font-sans); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; background: var(--gold); color: var(--black); padding: 14px 28px; border: none; cursor: pointer; text-decoration: none; display: inline-block; font-weight: 600; }
.btn-gold:hover { background: var(--gold-light); }

/* ======= HOME ======= */
#home { background: var(--black); }
.hero { min-height: calc(100vh - 64px); display: flex; flex-direction: column; justify-content: center; padding: 5rem 4rem 4rem; position: relative; overflow: hidden; background: linear-gradient(155deg,#0a0d0a 0%,#0f1a10 55%,#0a140a 100%); }
.hero-rule { width: 60px; height: 2px; background: var(--mint); margin-bottom: 2rem; }
.hero h1 { font-family: var(--font-display); font-size: clamp(3rem,6vw,5.5rem); font-weight: 900; line-height: 1.05; color: var(--warm-white); max-width: 700px; margin-bottom: 1.5rem; }
.hero h1 em { color: var(--mint); font-style: italic; }
.hero-sub { font-size: 1.05rem; color: rgba(253,252,248,0.68); max-width: 520px; margin-bottom: 2.5rem; line-height: 1.85; }
.hero-badges { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
.badge-pill { font-family: var(--font-sans); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; border: 1px solid rgba(77,191,138,0.35); color: var(--mint-pale); padding: 4px 12px; border-radius: 2px; }
.hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }

.value-strip { background: var(--forest); padding: 4rem; display: grid; grid-template-columns: repeat(3,1fr); gap: 3rem; position: relative; overflow: hidden; border-top: 1px solid rgba(77,191,138,0.12); }
.value-item h3 { font-family: var(--font-display); font-size: 1.45rem; font-weight: 700; color: var(--mint); margin-bottom: 0.75rem; }
.value-item p { font-size: 0.9rem; color: rgba(253,252,248,0.65); line-height: 1.85; }

.tr-home { background: var(--dark); padding: 6rem 4rem; display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; position: relative; overflow: hidden; border-top: 1px solid rgba(77,191,138,0.1); }
.tr-home h2 { font-family: var(--font-display); font-size: clamp(2rem,4vw,3.2rem); font-weight: 900; color: var(--warm-white); line-height: 1.1; margin-bottom: 1.25rem; }
.tr-home h2 em { color: var(--mint); font-style: italic; }
.tr-home p { color: rgba(253,252,248,0.68); font-size: 0.95rem; line-height: 1.9; margin-bottom: 1.15rem; }
.spec-stack { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 2rem; }
.spec-row { font-family: var(--font-sans); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; border-left: 2px solid var(--mint); padding: 6px 12px; color: var(--mint-pale); background: rgba(77,191,138,0.06); }
.spec-row strong { color: var(--mint); margin-right: 0.5rem; }
.tr-box { display: flex; align-items: center; justify-content: center; width: 100%; border: 1px solid rgba(37,159,138,0.18); position: relative; overflow: hidden; background: #001b16; border-radius: 4px; }
.tr-box-num { font-family: var(--font-display); font-size: 9rem; font-weight: 900; font-style: italic; color: var(--mint); opacity: 0.12; line-height: 1; position: relative; z-index: 1; }
.tr-box-label { position: absolute; bottom: 0.75rem; left: 50%; transform: translateX(-50%); font-family: var(--font-sans); font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--mint); opacity: 0.6; white-space: nowrap; }

.cotm-home { background: var(--cream); padding: 6rem 4rem; display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; position: relative; overflow: hidden; }
.cotm-home h2 { font-family: var(--font-display); font-size: clamp(2rem,3.5vw,3rem); font-weight: 900; color: var(--black); line-height: 1.1; margin-bottom: 1.25rem; }
.cotm-home h2 em { color: var(--teal); font-style: italic; }
.cotm-home p { color: var(--text-muted); font-size: 0.95rem; line-height: 1.9; margin-bottom: 1.15rem; }
.cotm-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; border-left: 2px solid var(--teal); padding-left: 2rem; }
.stat-num { font-family: var(--font-display); font-size: 2.5rem; font-weight: 900; color: var(--black); line-height: 1; display: block; }
.stat-label { font-family: var(--font-sans); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); display: block; margin-top: 0.25rem; }

.testimonials { background: var(--black); padding: 5rem 4rem; display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; position: relative; overflow: hidden; }
.testimonial { border-left: 2px solid var(--mint); padding-left: 1.5rem; }
.testimonial blockquote { font-family: var(--font-display); font-style: italic; font-size: 1.05rem; color: var(--cream); line-height: 1.75; margin-bottom: 1rem; }
.testimonial cite { font-family: var(--font-sans); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mint); font-style: normal; }

.hours-bar { background: var(--forest); padding: 4rem; display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 3rem; border-top: 1px solid rgba(77,191,138,0.12); position: relative; overflow: hidden; }
.hours-bar h2 { font-family: var(--font-display); font-size: 2rem; font-weight: 700; color: var(--cream); margin-bottom: 1rem; grid-column: 1/-1; }
.hours-col h4 { font-family: var(--font-sans); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--mint); margin-bottom: 0.75rem; }
.hours-col p, .hours-col address { font-size: 0.9rem; color: rgba(253,252,248,0.68); line-height: 1.9; font-style: normal; }
.hours-col a { color: var(--mint-pale); text-decoration: none; }
.motto { font-family: var(--font-display); font-style: italic; color: var(--mint); font-size: 0.85rem; margin-top: 0.5rem; display: block; opacity: 0.8; }

/* ======= THIRD RULE PAGE ======= */
#thirdrule { background: var(--black); }
.tr-hero { min-height: calc(100vh - 64px); display: flex; flex-direction: column; justify-content: center; padding: 5rem 4rem; position: relative; overflow: hidden; background: linear-gradient(145deg,#020704 0%,#0a1a0c 50%,#071008 100%); }
.tr-hero-content { position: relative; z-index: 1; max-width: 660px; }
.tr-exclusive { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--font-sans); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold-light); border: 1px solid rgba(201,168,76,0.35); padding: 6px 14px; margin-bottom: 2rem; }
.tr-exclusive::before { content: ''; width: 6px; height: 6px; background: var(--gold); border-radius: 50%; flex-shrink: 0; }
.tr-hero h1 { font-family: var(--font-display); font-size: clamp(3rem,7vw,6rem); font-weight: 900; line-height: 1; color: var(--warm-white); margin-bottom: 0.5rem; }
.tr-hero h1 .th3 { color: var(--mint); font-style: italic; }
.tr-hero-sub { font-size: 1.05rem; color: rgba(253,252,248,0.62); max-width: 540px; margin: 1.5rem 0 2.5rem; line-height: 1.85; }
.tr-specs-hero { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; background: rgba(77,191,138,0.1); margin-bottom: 2.5rem; max-width: 560px; }
.tr-spec-cell { background: rgba(10,13,10,0.85); padding: 1.25rem 1rem; }
.tr-spec-cell-label { font-family: var(--font-sans); font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--mint); display: block; margin-bottom: 0.4rem; }
.tr-spec-cell-val { font-size: 0.85rem; color: var(--cream); line-height: 1.4; }
.tr-hero-visual { position: absolute; right: 0; top: 0; bottom: 0; width: 40%; display: flex; align-items: center; justify-content: center; overflow: hidden; }
.tr-hero-visual::before { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg,#020704 0%,transparent 40%); z-index: 1; }
.tr-big-3 { font-family: var(--font-display); font-size: 30vw; font-weight: 900; font-style: italic; color: var(--mint); opacity: 0.04; line-height: 1; position: absolute; right: -3vw; }

.tr-story { background: var(--jungle); padding: 6rem 4rem; display: grid; grid-template-columns: 3fr 2fr; gap: 5rem; position: relative; overflow: hidden; }
.tr-story h2 { font-family: var(--font-display); font-size: clamp(1.8rem,3vw,2.6rem); font-weight: 900; color: var(--warm-white); margin-bottom: 1.25rem; line-height: 1.15; }
.tr-story h2 em { color: var(--mint); font-style: italic; }
.tr-story p { color: rgba(253,252,248,0.7); font-size: 0.95rem; line-height: 1.95; margin-bottom: 1.25rem; }
.tr-story strong { color: var(--mint-pale); }
.tr-quote { border-left: 2px solid var(--mint); padding: 1rem 1.5rem; margin: 2rem 0; font-family: var(--font-display); font-style: italic; font-size: 1.05rem; color: var(--mint-pale); line-height: 1.72; }
.tr-quote cite { display: block; font-family: var(--font-sans); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mint); font-style: normal; margin-top: 0.75rem; }

.tr-sidebar-card { background: rgba(10,13,10,0.7); border: 1px solid rgba(77,191,138,0.15); padding: 1.75rem; margin-bottom: 1.25rem; }
.tr-sidebar-card h4 { font-family: var(--font-sans); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--mint); margin-bottom: 0.75rem; }
.tr-sidebar-card p { font-size: 0.875rem; color: rgba(253,252,248,0.62); line-height: 1.8; }
.spec-table { width: 100%; border-collapse: collapse; }
.spec-table tr { border-bottom: 1px solid rgba(77,191,138,0.1); }
.spec-table tr:last-child { border-bottom: none; }
.spec-table td { padding: 0.6rem 0; font-size: 0.875rem; }
.spec-table td:first-child { font-family: var(--font-sans); font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--mint); width: 38%; }
.spec-table td:last-child { color: rgba(253,252,248,0.72); }

.tr-cta { background: var(--dark); padding: 5rem 4rem; text-align: center; position: relative; overflow: hidden; border-top: 1px solid rgba(77,191,138,0.1); }
.tr-cta h2 { font-family: var(--font-display); font-size: clamp(2rem,4vw,3.2rem); font-weight: 900; color: var(--warm-white); margin-bottom: 1rem; line-height: 1.2; }
.tr-cta h2 em { color: var(--mint); font-style: italic; }
.tr-cta p { color: rgba(253,252,248,0.62); max-width: 480px; margin: 0 auto 2rem; font-size: 0.95rem; }

/* ======= ABOUT ======= */
#about { background: var(--warm-white); }
.about-hero { background: var(--dark); padding: 7rem 4rem 5rem; min-height: 48vh; display: flex; flex-direction: column; justify-content: flex-end; position: relative; overflow: hidden; }
.about-hero h1 { font-family: var(--font-display); font-size: clamp(2.5rem,5vw,4.5rem); font-weight: 900; color: var(--warm-white); line-height: 1.05; max-width: 640px; position: relative; z-index: 1; }
.about-hero h1 em { color: var(--mint); font-style: italic; }
.about-hero p { color: rgba(253,252,248,0.62); max-width: 520px; margin-top: 1.25rem; position: relative; z-index: 1; }
.about-body { padding: 5rem 4rem; display: grid; grid-template-columns: 3fr 2fr; gap: 5rem; }
.about-main h2 { font-family: var(--font-display); font-size: 1.8rem; font-weight: 700; color: var(--black); margin-bottom: 1.25rem; line-height: 1.2; margin-top: 2.5rem; }
.about-main h2:first-child { margin-top: 0; }
.about-main p { color: var(--text-muted); margin-bottom: 1.25rem; font-size: 0.95rem; line-height: 1.9; }
.about-main p strong { color: var(--text); font-weight: 700; }
.sidebar-card { background: var(--forest); padding: 1.75rem; margin-bottom: 1.25rem; border-left: 3px solid var(--mint); }
.sidebar-card h4 { font-family: var(--font-sans); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--mint); margin-bottom: 0.75rem; }
.sidebar-card p { font-size: 0.875rem; color: rgba(253,252,248,0.7); line-height: 1.8; }
.mission-strip { background: var(--mint); padding: 4rem; text-align: center; }
.mission-strip h2 { font-family: var(--font-display); font-size: clamp(1.5rem,3vw,2.5rem); font-weight: 900; font-style: italic; color: var(--black); max-width: 700px; margin: 0 auto; line-height: 1.3; }
.mission-strip p { font-family: var(--font-sans); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(10,13,10,0.5); margin-top: 1rem; }

/* ======= COTM ======= */
#cotm { background: var(--cream); }
.cotm-hero { background: var(--black); padding: 7rem 4rem 5rem; min-height: 42vh; display: flex; flex-direction: column; justify-content: flex-end; position: relative; overflow: hidden; }
.cotm-hero h1 { font-family: var(--font-display); font-size: clamp(2.5rem,5vw,4rem); font-weight: 900; color: var(--warm-white); line-height: 1.05; max-width: 600px; position: relative; z-index: 1; }
.cotm-hero h1 em { color: var(--mint); font-style: italic; }
.cotm-hero p { color: rgba(253,252,248,0.62); max-width: 500px; margin-top: 1rem; position: relative; z-index: 1; }
.cotm-perks { background: var(--forest); padding: 4rem; display: grid; grid-template-columns: repeat(3,1fr); gap: 2.5rem; position: relative; overflow: hidden; border-bottom: 1px solid rgba(77,191,138,0.12); }
.perk h4 { font-family: var(--font-sans); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--mint); margin-bottom: 0.6rem; }
.perk p { font-size: 0.9rem; color: rgba(253,252,248,0.68); line-height: 1.85; }
.cotm-selection { padding: 5rem 4rem; }
.cotm-selection h2 { font-family: var(--font-display); font-size: 2.2rem; font-weight: 900; color: var(--black); margin-bottom: 0.5rem; }
.cotm-selection > p { color: var(--text-muted); margin-bottom: 3rem; font-size: 0.95rem; }
.cigar-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(280px,1fr)); gap: 1.5rem; margin-bottom: 3rem; }
.cigar-card { background: var(--warm-white); border: 1px solid var(--border); padding: 1.75rem; }
.cigar-card::before { content: ''; display: block; width: 28px; height: 2px; background: var(--mint); margin-bottom: 1rem; }
.cigar-card h3 { font-family: var(--font-display); font-size: 1.1rem; font-weight: 700; color: var(--black); margin-bottom: 0.5rem; line-height: 1.3; }
.cigar-meta { font-family: var(--font-sans); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--teal); margin-bottom: 0.75rem; }
.cigar-card p { font-size: 0.875rem; color: var(--text-muted); line-height: 1.8; }
.cotm-cta { background: var(--dark); padding: 5rem 4rem; text-align: center; position: relative; overflow: hidden; }
.cotm-cta h2 { font-family: var(--font-display); font-size: clamp(1.8rem,3.5vw,3rem); font-weight: 900; color: var(--warm-white); margin-bottom: 1rem; line-height: 1.2; }
.cotm-cta h2 em { color: var(--mint); font-style: italic; }
.cotm-cta p { color: rgba(253,252,248,0.62); max-width: 480px; margin: 0 auto 2rem; font-size: 0.95rem; }

/* ======= EVENTS ======= */
#events { background: var(--warm-white); }
.events-hero { background: var(--jungle); padding: 7rem 4rem 5rem; min-height: 38vh; display: flex; flex-direction: column; justify-content: flex-end; position: relative; overflow: hidden; }
.events-hero h1 { font-family: var(--font-display); font-size: clamp(2.5rem,5vw,4rem); font-weight: 900; color: var(--warm-white); line-height: 1.05; position: relative; z-index: 1; }
.events-hero h1 em { color: var(--mint); font-style: italic; }
.events-hero p { color: rgba(253,252,248,0.62); margin-top: 1rem; max-width: 520px; position: relative; z-index: 1; }
.events-grid { padding: 5rem 4rem; display: grid; grid-template-columns: repeat(auto-fit,minmax(300px,1fr)); gap: 2rem; }
.event-card { border: 1px solid var(--border); padding: 2rem; background: var(--warm-white); position: relative; overflow: hidden; }
.event-card::after { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 3px; background: var(--mint); }
.event-day { font-family: var(--font-sans); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--teal); margin-bottom: 0.6rem; }
.event-card h3 { font-family: var(--font-display); font-size: 1.3rem; font-weight: 700; color: var(--black); margin-bottom: 0.75rem; line-height: 1.25; }
.event-card p { font-size: 0.9rem; color: var(--text-muted); line-height: 1.8; }
.event-list { margin-top: 0.75rem; padding-left: 0; list-style: none; }
.event-list li { font-size: 0.875rem; color: var(--text-muted); padding: 0.35rem 0; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; }
.event-list li:last-child { border-bottom: none; }
.event-list .date { font-family: var(--font-sans); font-size: 10px; letter-spacing: 0.08em; color: var(--teal); font-weight: 600; white-space: nowrap; margin-left: 1rem; }
.events-note { background: var(--forest); padding: 3rem 4rem; text-align: center; }
.events-note p { color: rgba(253,252,248,0.7); font-size: 0.95rem; margin-bottom: 1.5rem; }
.events-note strong { color: var(--mint); }

/* ======= CONTACT ======= */
#contact { background: var(--cream); }
.contact-hero { background: var(--black); padding: 7rem 4rem 5rem; min-height: 33vh; display: flex; flex-direction: column; justify-content: flex-end; position: relative; overflow: hidden; }
.contact-hero h1 { font-family: var(--font-display); font-size: clamp(2.5rem,5vw,4rem); font-weight: 900; color: var(--warm-white); line-height: 1.05; position: relative; z-index: 1; }
.contact-hero h1 em { color: var(--mint); font-style: italic; }
.contact-hero p { color: rgba(253,252,248,0.62); margin-top: 1rem; position: relative; z-index: 1; }
.contact-grid { padding: 5rem 4rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; }
.contact-info h2 { font-family: var(--font-display); font-size: 1.6rem; font-weight: 700; color: var(--black); margin-bottom: 2rem; }
.contact-block { margin-bottom: 2rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border); }
.contact-block:last-child { border-bottom: none; }
.contact-block h4 { font-family: var(--font-sans); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--teal); margin-bottom: 0.6rem; }
.contact-block p, .contact-block address { font-size: 0.95rem; color: var(--text); line-height: 1.85; font-style: normal; }
.contact-block a { color: var(--teal); }
.map-placeholder { background: var(--forest); border: 1px solid rgba(77,191,138,0.15); display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 1rem; min-height: 380px; font-family: var(--font-sans); font-size: 11px; text-align: center; padding: 2rem; }
.map-placeholder strong { color: rgba(253,252,248,0.5); letter-spacing: 0.08em; font-size: 12px; }
.map-placeholder p { color: rgba(253,252,248,0.3); max-width: 220px; line-height: 1.6; font-size: 12px; }

/* ======= INSIDER ======= */
#insider { background: var(--black); }
.insider-hero { min-height: calc(100vh - 64px); display: flex; flex-direction: column; justify-content: center; padding: 5rem 4rem; position: relative; overflow: hidden; background: linear-gradient(155deg,#020704 0%,#0a1a0c 60%,#020704 100%); }
.insider-content { max-width: 600px; position: relative; z-index: 1; }
.insider-content h1 { font-family: var(--font-display); font-size: clamp(2.5rem,5vw,4.5rem); font-weight: 900; color: var(--warm-white); line-height: 1.05; margin-bottom: 1.5rem; }
.insider-content h1 em { color: var(--mint); font-style: italic; }
.insider-content p { color: rgba(253,252,248,0.65); font-size: 1rem; line-height: 1.9; margin-bottom: 1rem; }
.insider-perks { margin: 2rem 0; display: flex; flex-direction: column; gap: 0.75rem; }
.insider-perk { display: flex; align-items: flex-start; gap: 1rem; font-size: 0.9rem; color: rgba(253,252,248,0.75); }
.perk-dot { width: 6px; height: 6px; background: var(--mint); border-radius: 50%; margin-top: 0.55rem; flex-shrink: 0; }
.signup-form { margin-top: 2.5rem; display: flex; max-width: 480px; border: 1px solid rgba(77,191,138,0.35); }
.signup-form input { flex: 1; background: rgba(255,255,255,0.04); border: none; padding: 14px 18px; color: var(--cream); font-family: var(--font-body); font-size: 0.9rem; outline: none; }
.signup-form input::placeholder { color: rgba(253,252,248,0.25); }
.signup-form button { background: var(--mint); color: var(--black); border: none; padding: 14px 24px; font-family: var(--font-sans); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 600; cursor: pointer; white-space: nowrap; }
.signup-form button:hover { background: var(--mint-pale); color: var(--forest); }
.form-note { font-family: var(--font-sans); font-size: 10px; letter-spacing: 0.08em; color: rgba(253,252,248,0.22); margin-top: 0.75rem; }
.insider-tagline { margin-top: 4rem; padding-top: 2rem; border-top: 1px solid rgba(77,191,138,0.15); font-family: var(--font-display); font-style: italic; color: var(--mint); font-size: 1.1rem; opacity: 0.8; }

/* FOOTER */
.site-footer { background: var(--black); border-top: 1px solid rgba(77,191,138,0.1); padding: 2rem 4rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }
.footer-copy { font-family: var(--font-sans); font-size: 10px; letter-spacing: 0.08em; color: rgba(253,252,248,0.25); }
.footer-motto { font-family: var(--font-display); font-style: italic; color: var(--mint); font-size: 0.9rem; opacity: 0.65; }

/* RESPONSIVE */

@media (max-width: 768px) {
  .value-strip,.tr-home,.cotm-home,.testimonials,.hours-bar,.about-body,.cotm-perks,.contact-grid,.tr-story { grid-template-columns: 1fr; padding: 3rem 1.5rem; gap: 2rem; }
  .hero,.about-hero,.cotm-hero,.events-hero,.contact-hero,.insider-hero,.tr-hero { padding: 5rem 1.5rem 3rem; }
  .events-grid,.cotm-selection { padding: 3rem 1.5rem; }
  .mission-strip,.events-note,.cotm-cta,.tr-cta { padding: 3rem 1.5rem; }
  .site-footer { padding: 2rem 1.5rem; }
  .hours-bar h2 { grid-column: 1; }
  .signup-form { flex-direction: column; }
  .tr-specs-hero { grid-template-columns: 1fr; }
  .nav-links { display: none; }
}
</style>

