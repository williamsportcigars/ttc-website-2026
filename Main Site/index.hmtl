<!-- AGE GATE -->
<div id="age-gate" style="position:fixed;inset:0;z-index:9999;background:#001b16;display:flex;align-items:center;justify-content:center;padding:2rem;">
  <div style="max-width:480px;width:100%;text-align:center;position:relative;">

    <!-- Monstera leaf decorations -->
    <svg style="position:absolute;left:-15%;top:-20%;width:55%;opacity:0.07;pointer-events:none;" viewBox="0 0 500 640" fill="none"><path d="M250 30 C165 65 55 175 45 310 C35 445 115 570 240 580 C365 590 455 470 455 335 C455 200 355 55 250 30Z" fill="#259f8a"/><path d="M250 30 L250 580" stroke="#259f8a" stroke-width="4"/><path d="M120 155 C165 200 210 210 250 192" stroke="#259f8a" stroke-width="2.5"/><path d="M75 275 C135 305 195 312 250 290" stroke="#259f8a" stroke-width="2.5"/><path d="M85 395 C145 415 205 418 250 398" stroke="#259f8a" stroke-width="2.5"/><ellipse cx="130" cy="185" rx="35" ry="17" fill="none" stroke="#259f8a" stroke-width="1.8"/><ellipse cx="85" cy="308" rx="30" ry="14" fill="none" stroke="#259f8a" stroke-width="1.8"/></svg>
    <svg style="position:absolute;right:-15%;bottom:-20%;width:45%;opacity:0.06;pointer-events:none;" viewBox="0 0 400 520" fill="none"><path d="M200 25 C125 60 35 165 40 295 C45 425 140 510 245 495 C350 480 415 370 405 245 C395 120 285 25 200 25Z" fill="#259f8a"/><path d="M200 25 L200 495" stroke="#259f8a" stroke-width="3"/><path d="M95 145 C135 180 170 185 200 168" stroke="#259f8a" stroke-width="2"/><path d="M60 260 C112 282 158 286 200 265" stroke="#259f8a" stroke-width="2"/></svg>

    <!-- Logo -->
    <div style="width:90px;height:90px;margin:0 auto 2rem;border:1px solid rgba(37,159,138,0.2);border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(37,159,138,0.05);">
      <svg viewBox="0 0 60 60" fill="none" style="width:48px;height:48px;opacity:0.8;">
        <circle cx="30" cy="30" r="28" stroke="#259f8a" stroke-width="1.5"/>
        <text x="30" y="36" font-family="Georgia,serif" font-size="13" font-weight="900" fill="#259f8a" text-anchor="middle" font-style="italic">TTC</text>
      </svg>
    </div>

    <!-- Rule -->
    <div style="width:40px;height:2px;background:#259f8a;margin:0 auto 1.5rem;"></div>

    <!-- Heading -->
    <h1 style="font-family:'Playfair Display',Georgia,serif;font-size:clamp(1.8rem,4vw,2.6rem);font-weight:900;color:#f7fffe;line-height:1.1;margin-bottom:0.75rem;">You Must Be <em style="color:#259f8a;font-style:italic;">21 or Older</em></h1>
    <p style="font-family:'Libre Baskerville',Georgia,serif;font-size:0.9rem;color:rgba(253,252,248,0.6);line-height:1.8;margin-bottom:2.5rem;">The Tobacco Center sells tobacco products for adults only. By entering, you confirm you are 21 years of age or older.</p>

    <!-- Buttons -->
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-bottom:2rem;">
      <button onclick="enterSite()" style="font-family:'Josefin Sans',sans-serif;font-size:12px;letter-spacing:0.14em;text-transform:uppercase;background:#259f8a;color:#001b16;padding:15px 36px;border:none;cursor:pointer;font-weight:600;">Yes, I Am 21+</button>
      <button onclick="denySite()" style="font-family:'Josefin Sans',sans-serif;font-size:12px;letter-spacing:0.14em;text-transform:uppercase;background:transparent;color:rgba(253,252,248,0.5);padding:14px 36px;border:1px solid rgba(253,252,248,0.15);cursor:pointer;">No, Take Me Back</button>
    </div>

    <!-- Fine print -->
    <p style="font-family:'Josefin Sans',sans-serif;font-size:9px;letter-spacing:0.12em;text-transform:uppercase;color:rgba(253,252,248,0.2);line-height:1.7;">The Tobacco Center LLC · 21 W Church St, Williamsport, PA<br>Tobacco products are intended for adults 21+ only.</p>
  </div>
</div>

<script>
  (function() {
    // Check session — don't show again if already verified this session
    if (sessionStorage.getItem('ttc-age-verified') === 'yes') {
      document.getElementById('age-gate').style.display = 'none';
    }
  })();

  function enterSite() {
    sessionStorage.setItem('ttc-age-verified', 'yes');
    var gate = document.getElementById('age-gate');
    gate.style.transition = 'opacity 0.4s ease';
    gate.style.opacity = '0';
    setTimeout(function() { gate.style.display = 'none'; }, 400);
  }

  function denySite() {
    window.location.href = 'https://www.google.com';
  }
</script>
<!-- END AGE GATE -->


